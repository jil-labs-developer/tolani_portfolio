gr;font-weight:400;font-size:24px\" class=\"view-mode unstyled style-7cc6e3bd-5d46-4361-b5f6-b655c59cfb32\"><span style=\"font-weight:400;font-style:normal;font-family:ftgr;font-size:24px\">Hello,</span></p></div></div>","style":"left: 20px; top: 496px; width: 280px; height: 36px; z-index: 307;"},{"type":"text","cls":"rmwidget widget-text-v3","rect":{"left":20,"top":539,"width":280,"height":384,"z":308},"dataId":"69df6b4f6bdbe069bacaa261","html":"<div class=\"css-1hjul1e\"><div class=\"text-viewer\"><p style=\"line-height:24px;font-family:DM Sans;font-weight:400;font-size:12px\" class=\"view-mode unstyled style-7cc6e3bd-5d46-4361-b5f6-b655c59cfb32\"><span style=\"font-family:DM Sans;font-weight:400;font-style:normal;font-size:12px\">I'm an interaction and product designer finishing my Master's in Human-Computer Interaction at Indiana University Bloomington. I care deeply about the details that make experiences feel right and the big visions that give those details meaning.</span></p><p style=\"line-height:24px;font-family:DM Sans;font-weight:400;font-size:12px\" class=\"view-mode unstyled style-7cc6e3bd-5d46-4361-b5f6-b655c59cfb32\"><br></p><p style=\"line-height:24px;font-family:DM Sans;font-weight:400;font-size:12px\" class=\"view-mode unstyled style-7cc6e3bd-5d46-4361-b5f6-b655c59cfb32\"><span style=\"font-family:DM Sans;font-weight:400;font-style:normal;font-size:12px\">Outside of design, I go down rabbit holes for fun—reading about how Daoism celebrates forgetting, rewatching Love Island through a sociological lens, and consuming Merthur fanfic after a stressful day. I love the theatre, books, afrobeats, the cello, and pretty films.</span></p><p style=\"line-height:24px;font-family:DM Sans;font-weight:400;font-size:12px\" class=\"view-mode unstyled style-7cc6e3bd-5d46-4361-b5f6-b655c59cfb32\"><br></p><p style=\"line-height:24px;font-family:DM Sans;font-weight:400;font-size:12px\" class=\"view-mode unstyled style-7cc6e3bd-5d46-4361-b5f6-b655c59cfb32\"><span style=\"font-family:DM Sans;font-weight:400;font-style:normal;font-size:12px\">If you'd like to connect, you can reach me by <a role=\"link\" tabindex=\"0\" class=\"link-style-958062a5-7849-4edc-a4ad-f485b1d0ad32 external-link\" href=\"mailto:oluwatolaniadekoya@gmail.com\">email</a> or on <a role=\"link\" tabindex=\"0\" class=\"link-style-958062a5-7849-4edc-a4ad-f485b1d0ad32 external-link\" rel=\"noopener noreferrer\" target=\"_self\" href=\"http://www.linkedin.com/in/oluwatolani\">linkedin</a>, or grab my <a role=\"link\" tabindex=\"0\" class=\"link-style-958062a5-7849-4edc-a4ad-f485b1d0ad32 external-link\" rel=\"noopener noreferrer\" target=\"_self\" href=\"https://drive.google.com/file/d/1WHyAY5b-c7v2Zb5oaMjG2V47J73SU1jn/view?usp=sharing\">resume</a>.</span></p></div></div>","style":"left: 20px; top: 539px; width: 280px; height: 384px; z-index: 308;"},{"type":"text","cls":"rmwidget widget-text-v3","rect":{"left":20,"top":943,"width":280,"height":72,"z":309},"dataId":"69df6e182a588bac66966e24","html":"<div class=\"css-1hjul1e\"><div class=\"text-viewer\"><p style=\"line-height:36px;font-family:ftgr;font-weight:400;font-size:24px\" class=\"view-mode unstyled style-7cc6e3bd-5d46-4361-b5f6-b655c59cfb32\"><span style=\"font-weight:400;font-style:normal;font-family:ftgr;font-size:24px\">Staying curious,</span></p><p style=\"line-height:36px;font-family:ftgr;font-weight:400;font-size:24px\" class=\"view-mode unstyled style-7cc6e3bd-5d46-4361-b5f6-b655c59cfb32\"><span style=\"font-weight:400;font-style:normal;font-family:ftgr;font-size:24px\">Tolani</span></p></div></div>","style":"left: 20px; top: 943px; width: 280px; height: 72px; z-index: 309;"},{"type":"text","cls":"rmwidget widget-text-v3","rect":{"left":28,"top":1104.44,"width":54.1,"height":12,"z":323},"dataId":"69e23b4823930f319d559092","html":"<div class=\"css-1hjul1e\"><div class=\"text-viewer\"><p style=\"line-height:12px;font-family:IBM Plex Mono;font-weight:400;font-size:7px\" class=\"view-mode unstyled style-97