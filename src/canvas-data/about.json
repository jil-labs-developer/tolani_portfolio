font-family:DM Sans;font-weight:400;font-size:12px\" class=\"view-mode unstyled style-7cc6e3bd-5d46-4361-b5f6-b655c59cfb32\"><br></p></div></div>","style":"left: 272px; top: 165px; width: 480px; height: 36px; z-index: 310;"},{"type":"text","cls":"rmwidget widget-text-v3","rect":{"left":571,"top":180.86,"width":348.62,"height":336,"z":308},"dataId":"69df6b4f6bdbe069bacaa261","html":"<div class=\"css-q2pcac\"><div class=\"text-viewer\"><p style=\"line-height:24px;font-family:DM Sans;font-weight:400;font-size:12px\" class=\"view-mode unstyled style-7cc6e3bd-5d46-4361-b5f6-b655c59cfb32\"><span style=\"font-family:DM Sans;font-weight:400;font-style:normal;font-size:12px\">I'm an interaction and product designer finishing my Master's in Human-Computer Interaction at Indiana University Bloomington. I care deeply about the details that make experiences feel right and the big visions that give those details meaning.</span></p><p style=\"line-height:24px;font-family:DM Sans;font-weight:400;font-size:12px\" class=\"view-mode unstyled style-7cc6e3bd-5d46-4361-b5f6-b655c59cfb32\"><br></p><p style=\"line-height:24px;font-family:DM Sans;font-weight:400;font-size:12px\" class=\"view-mode unstyled style-7cc6e3bd-5d46-4361-b5f6-b655c59cfb32\"><span style=\"font-family:DM Sans;font-weight:400;font-style:normal;font-size:12px\">Outside of design, I go down rabbit holes for fun—reading about how Daoism celebrates forgetting, rewatching Love Island through a sociological lens, and consuming Merthur fanfic after a stressful day. I love the theatre, books, afrobeats, the cello, and pretty films.</span></p><p style=\"line-height:24px;font-family:DM Sans;font-weight:400;font-size:12px\" class=\"view-mode unstyled style-7cc6e3bd-5d46-4361-b5f6-b655c59cfb32\"><br></p><p style=\"line-height:24px;font-family:DM Sans;font-weight:400;font-size:12px\" class=\"view-mode unstyled style-7cc6e3bd-5d46-4361-b5f6-b655c59cfb32\"><span style=\"font-family:DM Sans;font-weight:400;font-style:normal;font-size:12px\">I<span style=\"text-decoration:none\">f you'd like to connect, you can reach me by </span><span style=\"text-decoration:underline\"><a role=\"link\" tabindex=\"0\" class=\"link-style-958062a5-7849-4edc-a4ad-f485b1d0ad32 external-link\" href=\"mailto:oluwatolaniadekoya@gmail.com\">email</a></span><span style=\"text-decoration:none\"> or on </span><span style=\"text-decoration:underline\"><a role=\"link\" tabindex=\"0\" class=\"link-style-958062a5-7849-4edc-a4ad-f485b1d0ad32 external-link\" rel=\"noopener noreferrer\" target=\"_self\" href=\"http://www.linkedin.com/in/oluwatolani\">linkedin</a></span>, or grab my <span style=\"text-decoration:underline\"><a role=\"link\" tabindex=\"0\" class=\"link-style-958062a5-7849-4edc-a4ad-f485b1d0ad32 external-link\" rel=\"noopener noreferrer\" target=\"_self\" href=\"https://drive.google.com/file/d/1WHyAY5b-c7v2Zb5oaMjG2V47J73SU1jn/view?usp=sharing\">resume</a></span>.</span></p></div></div>","style":"left: 571px; top: 180.86px; width: 348.62px; height: 336px; z-index: 308;"},{"type":"text","cls":"rmwidget widget-text-v3","rect":{"left":567,"top":544.46,"width":337.8,"height":72,"z":309},"dataId":"69df6e182a588bac66966e24","html":"<div class=\"css-q2pcac\"><div class=\"text-viewer\"><p style=\"line-height:36px;font-family:ftgr;font-weight:400;font-size:24px\" class=\"view-mode unstyled style-7cc6e3bd-5d46-4361-b5f6-b655c59cfb32\"><span style=\"font-weight:400;font-style:normal;font-family:ftgr;font-size:24px\">Staying curious,</span></p><p style=\"line-height:36px;font-family:ftgr;font-weight:400;font-size:24px\" class=\"view-mode unstyled style-7cc6e3bd-5d46-4361-b5f6-b655c59cfb32\"><span style=\"font-weight:400;font-style:normal;font-family:ftgr;font-size:24px\">Tolani</span></p></div></div>","style":"left: 567px; top: 544.46px; width: 337.8px; height: 72px; z-index: 309;"},{"type":"text","cls":"rmwidget widget-text-v3","rect":{"left":29,"top":740.01,"width":160.28,"height":25,"z":313},"dataId":"69df7c51eb29ab14c46cad